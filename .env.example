# ─────────────────────────────────────────────────────────────────────────────
# Dragon Ball Z Cyber Arena — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core Flask ────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker Compose:
DATABASE_URL=postgresql://ctf:ctf@localhost:5432/ctfdb
# Render.com: set automatically via render.yaml fromDatabase

# ── Admin Bootstrap (auto-created on first run) ───────────────────────────────
ADMIN_EMAIL=admin@ctf.local
ADMIN_PASSWORD=ChangeMe123!

# ── CTF Configuration ─────────────────────────────────────────────────────────
FLAG_PREFIX=THA
CTF_NAME=Dragon Ball Z Cyber Arena
MAX_TEAM_SIZE=3
MAX_ATTEMPTS=10
PENALTY_POINTS=10
SCOREBOARD_CACHE_TTL=10
FREEZE_MINUTES_BEFORE_END=60

# ── Dynamic Flags ─────────────────────────────────────────────────────────────
DYNAMIC_FLAG_SECRET=change-this-to-a-secret-string

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Set MAIL_SUPPRESS_SEND=true in development to skip actual emails
MAIL_SUPPRESS_SEND=true
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@yourdomain.com

# ── Uploads ───────────────────────────────────────────────────────────────────
# Leave blank to use default (app/static/uploads)
# UPLOAD_FOLDER=/path/to/uploads
